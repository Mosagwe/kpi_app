{
  "name": "kpi-appraisal-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "KPI appraisal workspace with AI-assisted achievement refinement and Excel export.",
  "type": "module",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "node --watch backend/server.js",
    "dev:frontend": "vite --host 0.0.0.0",
    "build": "vite build",
    "test": "node --test",
    "check": "node --check backend/server.js && node --check backend/lib/kpi.js && npm run build"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "@vitejs/plugin-react": "^6.0.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.17.0",
    "multer": "^2.0.2",
    "openai": "^6.42.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "redux": "^5.0.1",
    "sweetalert2": "^11.26.25",
    "undici": "^6.21.3",
    "vite": "^8.1.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
